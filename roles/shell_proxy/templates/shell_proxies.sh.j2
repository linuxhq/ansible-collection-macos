# {{ shell_proxy_file | basename }}

{% macro proxy_url(protocol, hostname, port, username, password) %}
{%-   if username is not none and password is not none %}
{%-     set username = username | urlencode | replace('/', '%2F') %}
{%-     set password = password | urlencode | replace('/', '%2F') %}
{{-     protocol }}://{{ username }}:{{ password }}@{{ hostname }}:{{ port }}
{%-   else %}
{{-     protocol }}://{{ hostname }}:{{ port }}
{%-   endif %}
{%- endmacro %}
{% if shell_proxy_noproxy | length > 0 %}
export no_proxy="{{ shell_proxy_noproxy | join(',') }}"
{% endif %}
{% if shell_proxy_ftp | bool %}
export ftp_proxy="{{ proxy_url(shell_proxy_ftp_protocol,
                               shell_proxy_ftp_hostname,
                               shell_proxy_ftp_port,
                               shell_proxy_ftp_username,
                               shell_proxy_ftp_password) }}"
{% endif %}
{% if shell_proxy_http | bool %}
export http_proxy="{{ proxy_url(shell_proxy_http_protocol,
                                shell_proxy_http_hostname,
                                shell_proxy_http_port,
                                shell_proxy_http_username,
                                shell_proxy_http_password) }}"
{% endif %}
{% if shell_proxy_https | bool %}
export https_proxy="{{ proxy_url(shell_proxy_https_protocol,
                                 shell_proxy_https_hostname,
                                 shell_proxy_https_port,
                                 shell_proxy_https_username,
                                 shell_proxy_https_password) }}"
{% endif %}
